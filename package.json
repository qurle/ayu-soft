{
  "name": "ayu-soft",
  "displayName": "Ayu Soft",
  "description": "A soften fork of Auy Mirage theme",
  "version": "1.2.2",
  "publisher": "qurle",
  "author": {
    "name": "Nikita Denisov",
    "email": "nick@qurle.net"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/qurle/ayu-soft"
  },
  "bugs": {
    "url": "https://github.com/qurle/ayu-soft/issues",
    "email": "nick@qurle.net"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "icon-theme",
    "theme",
    "ayu"
  ],
  "homepage": "https://github.com/qurle/ayu-soft",
  "icon": "assets/logo.png",
  "contributes": {
    "themes": [
      {
        "label": "Ayu Mirage Soft",
        "uiTheme": "vs-dark",
        "path": "./ayu-mirage-soft.json"
      },
      {
        "label": "Ayu Mirage Soft And Fresh",
        "uiTheme": "vs-dark",
        "path": "./ayu-mirage-soft-and-fresh.json"
      }
    ]
  },
  "scripts": {
    "start": "tsx --watch ./src/build.ts",
    "build": "tsx ./src/build.ts && vsce package",
    "publish": "vsce publish"
