{
  "name": "ayu",
  "version": "9.1.0-beta.0",
  "description": "The ayu sublime theme as a color palette",
  "type": "module",
  "main": "./dist/colors.js",
  "types": "./dist/colors.d.ts",
  "exports": {
    ".": {
      "types": "./dist/colors.d.ts",
      "default": "./dist/colors.js"
    },
    "./color": {
      "types": "./dist/color.d.ts",
      "default": "./dist/color.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "default": "./dist/icons.js"
    }
  },
  "scripts": {
    "generate": "node --loader ts-node/esm scripts/generate-themes.ts",
    "build": "npm run generate && node --loader ts-node/esm scripts/generate-types.ts && tsc && cp src/scheme.d.ts dist/",
    "test": "npm run build && node --loader ts-node/esm --test scripts/test.ts",
    "designer": "next dev designer"
  },
  "files": [
    "dist",
    "icons"
  ],
  "repository": {
    "url": "https://github.com/ayu-theme/ayu-colors",
    "type": "git"
  },
  "author": "Konstantin Pschera <me@kons.ch>",
  "license": "MIT",
  "engines": {
    "node": ">=22.18.0"
  },
  "devDependencies": {
    "@floating-ui/react": "^0.27.16",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-tooltip": "^1.1.2",
    "@types/apca-w3": "^0.1.3",
    "@types/culori": "^4.0.1",
    "@types/node": "^20.10.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "apca-w3": "^0.1.9",
    "next": "^16.1.1",
    "react": "^19",
    "react-dom": "^19",
    "shiki": "^3.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0",
    "yaml": "^2.8.2",
    "zustand": "^5.0.0"
  },
  "dependencies": {
    "culori": "^4.0.1"
  }
}
